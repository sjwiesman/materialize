{
  "name": "mz-deploy-lsp",
  "displayName": "mz-deploy",
  "description": "SQL language support for mz-deploy projects via the mz-deploy LSP server",
  "version": "0.1.0",
  "publisher": "materialize",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "workspaceContains:project.toml"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch"
  },
  "contributes": {
    "configuration": {
      "title": "mz-deploy",
      "properties": {
        "mz-deploy.path": {
          "type": "string",
          "default": "mz-deploy",
          "description": "Path to the mz-deploy binary"
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "typescript": "^5.9.3"
  }
}
